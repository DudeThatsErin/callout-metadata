{
    "compilerOptions": {
        "baseUrl": ".",
        "module": "ESNext",
        "target": "ES6",
        "moduleResolution": "node",
        "strict": true,
        "skipLibCheck": true,
        "noImplicitAny": true,
        "esModuleInterop": true,
        "allowSyntheticDefaultImports": true,
        "types": [
            "node"
        ]
    },
    "include": [
        "src/**/*.ts"
    ]
}